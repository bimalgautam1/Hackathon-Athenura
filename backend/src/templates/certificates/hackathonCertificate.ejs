<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4 landscape;
            margin: 0;
        }
        body {
            margin: 0;
            padding: 0;
            font-family: 'Outfit', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fff;
        }
        .certificate-container {
            width: 297mm;
            height: 210mm;
            padding: 20mm;
            box-sizing: border-box;
            position: relative;
            background: #fff;
            border: 15px solid #2c3e50;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .inner-border {
            position: absolute;
            top: 5mm;
            left: 5mm;
            right: 5mm;
            bottom: 5mm;
            border: 2px solid #34495e;
            pointer-events: none;
        }
        .header {
            margin-bottom: 20px;
        }
        .logo {
            width: 120px;
            margin-bottom: 20px;
        }
        .title {
            font-size: 54px;
            color: #2c3e50;
            text-transform: uppercase;
            letter-spacing: 5px;
            margin: 0;
            font-weight: 800;
        }
        .subtitle {
            font-size: 20px;
            color: #7f8c8d;
            margin: 10px 0 40px 0;
            font-style: italic;
        }
        .present-text {
            font-size: 18px;
            color: #34495e;
            margin-bottom: 10px;
        }
        .recipient-name {
            font-size: 42px;
            color: #e67e22;
            font-weight: bold;
            border-bottom: 2px solid #bdc3c7;
            padding-bottom: 10px;
            margin-bottom: 30px;
            min-width: 400px;
        }
        .description {
            font-size: 18px;
            color: #2c3e50;
            max-width: 800px;
            margin-bottom: 40px;
            line-height: 1.5;
        }
        .award-badge {
            font-size: 24px;
            font-weight: bold;
            color: #27ae60;
            margin-bottom: 40px;
            text-transform: uppercase;
        }
        .footer {
            width: 100%;
            display: flex;
            justify-content: space-around;
            margin-top: 50px;
        }
        .signature-block {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .signature-line {
            width: 200px;
            border-top: 1px solid #34495e;
            margin-top: 10px;
        }
        .signature-name {
            font-size: 16px;
            color: #2c3e50;
            font-weight: bold;
        }
        .signature-title {
            font-size: 14px;
            color: #7f8c8d;
        }
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 150px;
            color: rgba(44, 62, 80, 0.03);
            z-index: -1;
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="certificate-container">
        <div class="inner-border"></div>
        <div class="watermark">ATHENURA</div>
        
        <div class="header">
            <!-- <img src="<%= logoUrl %>" alt="Athenura Logo" class="logo"> -->
            <h1 class="title">CERTIFICATE</h1>
            <p class="subtitle">OF ACHIEVEMENT</p>
        </div>

        <p class="present-text">THIS CERTIFICATE IS PROUDLY PRESENTED TO</p>
        <div class="recipient-name"><%= userName %></div>

        <p class="description">
            For outstanding performance and dedication shown in the 
            <strong><%= hackathonTitle %></strong>, 
            contributing the project <strong><%= submissionTitle %></strong>.
        </p>

        <div class="award-badge">
            <%= awardCategory %> - Rank #<%= rank %>
        </div>

        <div class="footer">
            <div class="signature-block">
                <span class="signature-name">Athenura Board</span>
                <div class="signature-line"></div>
                <span class="signature-title">Organizing Committee</span>
            </div>
            <div class="signature-block">
                <span class="signature-name"><%= new Date().toLocaleDateString() %></span>
                <div class="signature-line"></div>
                <span class="signature-title">Date of Issue</span>
            </div>
        </div>
    </div>
</body>
</html>
